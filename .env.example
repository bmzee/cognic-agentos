# Cognic AgentOS — example environment file.
# Copy to `.env` for local dev; never commit `.env`.
#
# Sprint 1A scope: server + profile only. 1B (observability) and 1C (adapters) extend this file.

# Server
COGNIC_HOST=127.0.0.1
COGNIC_PORT=8000
COGNIC_API_PREFIX=/api/v1

# Profile: dev | stage | prod
# `prod` profile flips multiple security defaults closed (per ADR-002 STDIO threat model + others).
COGNIC_RUNTIME_PROFILE=dev

# Logging
COGNIC_LOG_LEVEL=INFO
