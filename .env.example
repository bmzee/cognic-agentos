# Cognic AgentOS — example environment file.
# Copy to `.env` for local dev; never commit `.env`.
#
# Reflects Sprint 1A (server + profile) + Sprint 1B (observability stack)
# + Sprint 1C (adapter drivers).
# Sprint 1D will extend with enterprise adapter envs (Oracle, Dynatrace,
# OpenAI-compat embedding).

# --- Server ----------------------------------------------------------
COGNIC_HOST=127.0.0.1
COGNIC_PORT=8000
COGNIC_API_PREFIX=/api/v1

# --- Profile ---------------------------------------------------------
# Profile: dev | stage | prod
# `prod` profile flips multiple security defaults closed (per ADR-002 STDIO threat model
# + ADR-014 runtime tool approval + others).
COGNIC_RUNTIME_PROFILE=dev

# --- Logging (Sprint 1B) ---------------------------------------------
COGNIC_LOG_LEVEL=INFO
# json | text. `json` is the production default (SIEM-friendly); `text` is a
# developer convenience and is never used in stage/prod.
COGNIC_LOG_FORMAT=json

# --- OpenTelemetry tracing (Sprint 1B) -------------------------------
# OTLP gRPC endpoint for trace export. Leave unset in dev to fall back to
# the console exporter; leave unset in prod to install a no-op exporter
# (traces silently dropped rather than written to stdout, which would
# corrupt the JSON log stream).
# COGNIC_OTEL_EXPORTER_ENDPOINT=otel-collector:4317

# Default is False (TLS required). Set to true ONLY for local-collector
# dev work; never in stage/prod.
COGNIC_OTEL_EXPORTER_INSECURE=false

# mTLS / custom CA paths (set together; populated from Vault-mounted
# secrets in prod). Leave commented in dev.
# COGNIC_OTEL_EXPORTER_CA_CERT_PATH=/run/secrets/otel-ca.pem
# COGNIC_OTEL_EXPORTER_CLIENT_CERT_PATH=/run/secrets/otel-client.pem
# COGNIC_OTEL_EXPORTER_CLIENT_KEY_PATH=/run/secrets/otel-client.key

# --- Prometheus metrics (Sprint 1B) ----------------------------------
COGNIC_PROMETHEUS_METRICS_PATH=/metrics

# --- CORS allow-list (Sprint 1B) -------------------------------------
# Allowed input shapes (the loader accepts all three):
#   1. Comma-separated string  — operator-friendly
#       COGNIC_CORS_ALLOWED_ORIGINS=https://reviewer.bank.example,https://operator.bank.example
#   2. JSON array string       — automation-friendly
#       COGNIC_CORS_ALLOWED_ORIGINS=["https://reviewer.bank.example","https://operator.bank.example"]
#   3. Empty value             — default-deny (no CORS middleware mounted)
#       COGNIC_CORS_ALLOWED_ORIGINS=
#
# The literal `*` is forbidden in any shape (Phase-1 'CORS allow-list-only'
# principle). Default below is empty (default-deny).
COGNIC_CORS_ALLOWED_ORIGINS=

# --- Sprint 1C — Adapter drivers --------------------------------------
# Driver names map to bundled adapters in cognic_agentos.db.adapters.
# Setting an unknown driver causes startup to fail fast with
# AdapterNotInstalled (no silent fallback).

# Relational
COGNIC_DB_DRIVER=postgres
COGNIC_DATABASE_URL=postgresql+asyncpg://cognic:cognic_dev_only@localhost:5432/cognic_agentos

# Vector
COGNIC_VECTOR_DRIVER=qdrant
COGNIC_QDRANT_URL=http://localhost:6333
COGNIC_QDRANT_COLLECTION=cognic_default

# Secrets
COGNIC_SECRET_DRIVER=vault
COGNIC_VAULT_ADDR=http://localhost:8200
COGNIC_VAULT_TOKEN=dev-only-root
COGNIC_VAULT_NAMESPACE=

# Embedding
COGNIC_EMBED_DRIVER=ollama
COGNIC_EMBEDDING_MODEL=qwen3-embedding:8b
COGNIC_EMBEDDING_BASE_URL=http://localhost:11434
COGNIC_EMBEDDING_DIMENSIONS=1024

# Observability
COGNIC_OBS_DRIVER=langfuse_otel
COGNIC_LANGFUSE_HOST=http://localhost:3000
COGNIC_LANGFUSE_PUBLIC_KEY=pk-lf-dev
COGNIC_LANGFUSE_SECRET_KEY=sk-lf-dev

# ----- Sprint 1D — Enterprise adapters -----
# Oracle (uses the same DATABASE_URL field with oracle+oracledb:// scheme):
# COGNIC_DB_DRIVER=oracle
# COGNIC_DATABASE_URL=oracle+oracledb://cognic:cognic_dev_only@localhost:1521/?service_name=XEPDB1

# Dynatrace observability:
# COGNIC_OBS_DRIVER=dynatrace
# COGNIC_DYNATRACE_TENANT_URL=https://abc12345.live.dynatrace.com
# COGNIC_DYNATRACE_API_TOKEN=dt0c01.YOUR_API_TOKEN_HERE  # dev-only direct env; prod sources via Vault (Sprint 10)
# COGNIC_DYNATRACE_API_TOKEN_VAULT_PATH=secret/dynatrace/cognic  # reserved; Sprint 10 wires runtime resolution
# Required Dynatrace API token scopes: metrics.read (health probe) + metrics.ingest (emit_metric).

# OpenAI-compat embedding (vLLM / SGLang / OpenAI / Cohere / Azure-OAI-via-shim / Bedrock-via-shim):
# COGNIC_EMBED_DRIVER=openai_compat
# COGNIC_EMBEDDING_BASE_URL=http://vllm:8000   # or http://sglang:30000, https://api.openai.com, etc.
# COGNIC_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# COGNIC_EMBEDDING_DIMENSIONS=1024
# COGNIC_EMBED_PROVIDER_LABEL=vllm  # one of: vllm | sglang | openai | azure_oai | bedrock | cohere | openai_compat
# COGNIC_EMBEDDING_API_KEY=                    # leave unset for vLLM/SGLang local; "sk-..." for OpenAI; raw key for Azure
# COGNIC_EMBEDDING_API_KEY_HEADER=Authorization  # default; set to "api-key" for Azure-OpenAI proxies (raw, no Bearer prefix)
# COGNIC_EMBEDDING_API_KEY_VAULT_PATH=         # reserved; Sprint 10 wires runtime resolution
# COGNIC_EMBEDDING_EXTRA_HEADERS={}            # JSON dict; e.g. '{"api-version": "2024-02-15-preview"}' for Azure

# ----- Sprint 3 — LLM gateway + provider-honesty (per ADR-007) -----
# Tier aliases resolve to entries in infra/litellm/config.yaml and may point
# at EITHER local/self-hosted aliases (e.g. cognic-tier1-dev → ollama,
# cognic-tier1-vllm → private vLLM, cognic-tier1-sglang → private SGLang)
# OR cloud aliases (e.g. cognic-tier1-cloud-openai → OpenAI). Sprint 3 ships
# tier1/tier2 only; Sprint 9.5 (ADR-013) extends.
# COGNIC_TIER1_ALIAS=cognic-tier1-dev
# COGNIC_TIER2_ALIAS=cognic-tier2-dev
# COGNIC_LITELLM_BASE_URL=http://litellm:4000
# COGNIC_LITELLM_MASTER_KEY=                     # dev-only when set in source; prod via Vault (Sprint 10)
#
# Cloud-policy gates — self-hosted-first defaults. Set ALL of:
#   - COGNIC_ALLOW_EXTERNAL_LLM=true
#   - COGNIC_POLICY_MODE=cloud_openai            # or cloud_anthropic / cloud_mixed
#   - COGNIC_ALLOWED_PROVIDERS=openai            # CSV or JSON array; lowercased
# to permit any external upstream. Default state denies all external traffic.
# COGNIC_ALLOW_EXTERNAL_LLM=false
# COGNIC_POLICY_MODE=self_hosted                 # self_hosted | cloud_openai | cloud_anthropic | cloud_mixed
# COGNIC_ALLOWED_PROVIDERS=                      # e.g. "openai,azure" or '["openai", "azure"]'
#
# Cloud upstream credentials + per-tier model overrides (Sprint 3 T10).
# ONLY needed when the corresponding cloud alias is actually selected as
# the active tier (COGNIC_TIER1_ALIAS or COGNIC_TIER2_ALIAS) AND the
# operator has opened the cloud-policy gates above. The aliases live in
# infra/litellm/config.yaml; per-tier model overrides default to a current
# top-tier model when unset, so operators can switch upstream model
# checkpoints without editing the YAML.
#   - cognic-tier1-cloud-openai  → openai/${COGNIC_TIER1_CLOUD_OPENAI_MODEL:-gpt-4o}
#   - cognic-tier2-cloud-openai  → openai/${COGNIC_TIER2_CLOUD_OPENAI_MODEL:-gpt-4o-mini}
#   - cognic-tier1-cloud-anthropic → anthropic/${COGNIC_TIER1_CLOUD_ANTHROPIC_MODEL:-claude-3-5-sonnet-20241022}
#   - cognic-tier2-cloud-anthropic → anthropic/${COGNIC_TIER2_CLOUD_ANTHROPIC_MODEL:-claude-3-5-haiku-20241022}
# OPENAI_API_KEY=                                # required when a cognic-tier{1,2}-cloud-openai alias is active
# ANTHROPIC_API_KEY=                             # required when a cognic-tier{1,2}-cloud-anthropic alias is active
# COGNIC_TIER1_CLOUD_OPENAI_MODEL=               # override; default gpt-4o
# COGNIC_TIER2_CLOUD_OPENAI_MODEL=               # override; default gpt-4o-mini
# COGNIC_TIER1_CLOUD_ANTHROPIC_MODEL=            # override; default claude-3-5-sonnet-20241022
# COGNIC_TIER2_CLOUD_ANTHROPIC_MODEL=            # override; default claude-3-5-haiku-20241022
#
# Operational knobs.
# COGNIC_LLM_TIMEOUT_S=30.0
# COGNIC_LLM_CONCURRENCY_PER_PROFILE=4
# COGNIC_LLM_CONCURRENCY_MODE=queued             # queued | fail_fast
# COGNIC_PROVIDER_HONESTY_LEDGER_WINDOW_MINUTES=60   # /system/effective-routing window; capped at 1440 (24h)
#
# Per-route guardrail scope.
# Controls when configured gateway guardrail pipelines execute. Four modes:
#   - all                — secure default; run guardrails on local + cloud calls
#   - external_only      — run guardrails only for cloud/external upstreams
#                          (banks with fully on-prem models may skip local
#                          guardrails on perimeter-risk grounds)
#   - self_hosted_only   — run guardrails only for local/on-prem upstreams
#                          (e.g. operator who guards on-prem traffic but
#                          trusts cloud-tenant isolation)
#   - off                — skip configured pipelines on every call
# This knob controls whether configured pipelines execute; banks can still
# inject None for input or output pipeline at gateway construction to disable
# a direction globally. Two axes compose. Per ADR-007 self-hosted-first
# posture: AgentOS ships ``all``; banks intentionally relax based on perimeter.
# COGNIC_LLM_GUARDRAIL_SCOPE=all

# ----- Sprint 4 — Plugin registry + trust gate + policy seed (per ADRs 002 / 015 / 016) -----
# Per-tenant plugin allow-list. JSON: {tenant_id: [pack_name, ...]}. File-backed in
# Sprint 4; Vault swap → Sprint 10 (no API surface change at the swap).
# COGNIC_PLUGIN_ALLOWLIST_PATH=policies/_default/plugin_allowlist.json
#
# Trust gate (cosign).
# COGNIC_REQUIRE_COSIGN=true                     # default; setting false in prod is a critical-controls violation
# COGNIC_COSIGN_PATH=                            # leave unset to use shutil.which('cosign'); prod pins via Dockerfile
# COGNIC_COSIGN_VERIFY_TIMEOUT_S=30.0            # SIGKILL on timeout; timeout itself emits chained audit event
#
# Policy engine seed (per ADR-015 Sprint-4 phase).
# COGNIC_SUPPLY_CHAIN_POLICY_BUNDLE=policies/_default/supply_chain.rego
# COGNIC_OPA_PATH=                               # leave unset to use shutil.which('opa'); prod pins via Dockerfile
# COGNIC_OPA_EVAL_TIMEOUT_S=5.0
#
# LocalObjectStoreAdapter (per Sprint 4 — first real ObjectStoreAdapter impl per ADR-009 + ADR-016).
# Sprint 8 adds the S3 driver alongside; this filesystem path stays a production
# default for filesystem-backed deployments (NFS / EFS / single-host).
# COGNIC_LOCAL_OBJECT_STORE_ROOT=                # leave unset to derive from $TMPDIR (dev) or /var/lib/cognic-agentos/object-store (prod)
#
# Path-traversal prevention prefixes (boundary-asserted at the trust-gate).
# COGNIC_SIGNATURE_ROOT_PATH=attestations
# COGNIC_TRUST_ROOT_PREFIX=trust-roots

# ===== Sprint 5 — MCP host =====
# Per ADR-002 (MCP plugin protocol — OAuth/PRM authorization + STDIO four-gate
# threat model) + ADR-014 (transitional high-risk-tier refusal) + ADR-015
# (sampling default-deny Rego seed). Sprint-5 Decision Lock (Option C): STDIO
# in Sprint 5 ships threat model + manifest/config validation + fail-closed
# refusal at registration. STDIO does NOT ship process launch — that's
# Sprint 8 with the sandbox primitive.

# STDIO transport is hard-disabled by default in ALL profiles in Sprint 5
# (sandbox primitive lands Sprint 8). Setting this to True with
# COGNIC_RUNTIME_PROFILE=prod and no sandbox available => fail-fast at
# startup with SandboxNotAvailableError. See docs/MCP-STDIO-THREAT-MODEL.md.
# COGNIC_MCP_STDIO_ENABLED=false

# Vault path template for the per-tenant STDIO command allow-list.
# Per ADR-002 §MCP STDIO threat model gate 2.
# COGNIC_MCP_STDIO_COMMAND_ALLOWLIST_PATH=secret/cognic/{tenant}/stdio-command-allowlist

# Vault path template for the per-tenant OAuth authorization-server allow-list.
# Per ADR-002 §MCP Authorization step 3.
# COGNIC_MCP_AS_ALLOWLIST_PATH=secret/cognic/{tenant}/mcp-as-allowlist

# OAuth token cache TTL (seconds). Refresh emits audit.mcp_token_refresh on
# the audit_event chain plus a decision_history row per T11 correlation.
# COGNIC_MCP_OAUTH_TOKEN_CACHE_TTL_S=3600

# Strict timeout on every PRM discovery + token request HTTP call (seconds).
# Same fail-closed posture as cosign_verify_timeout_s.
# COGNIC_MCP_OAUTH_REQUEST_TIMEOUT_S=30

# Strict timeout on every MCP call_tool invocation (seconds).
# COGNIC_MCP_CALL_TOOL_TIMEOUT_S=60

# Sampling default-deny Rego bundle path (consumed by protocol/mcp_capabilities.py).
# Operators override per-tenant by pointing this at a Vault-mounted bundle.
# Default-deny posture: allow only when pack manifest, tenant policy,
# cloud-policy tier consistency, and allow_external_llm consistency all hold.
# COGNIC_MCP_SAMPLING_POLICY_BUNDLE=policies/_default/sampling.rego

# Vault path template for per-tenant per-AS OAuth client credentials. Resolved
# at token-acquisition time as path.format(tenant=tenant_id, as_host=<netloc>)
# where <netloc> is urlparse(as_issuer).netloc with ':' replaced by '_' so the
# value is safe as a Vault path segment. For an issuer like
# "https://as.example:8443" the as_host substitution becomes "as.example_8443"
# (underscore) — populate Vault accordingly. Issuers without an explicit port
# are unaffected.
# Vault secret shape: {client_id, client_secret, auth_method} where
# auth_method is one of "client_secret_post" / "client_secret_basic" (Sprint 5;
# Wave 2 adds private_key_jwt + mTLS). The MCP authz client never logs the
# secret. Operators MUST populate this path before MCP packs admit; missing
# credentials surface as the closed-enum mcp_oauth_credentials_missing
# refusal at registration time.
# COGNIC_MCP_OAUTH_CREDENTIALS_PATH=secret/cognic/{tenant}/mcp-oauth/{as_host}

# ----------------------------------------------------------------------------
# Sprint 6 — A2A endpoint (per ADR-003 + docs/A2A-CONFORMANCE.md) + UI
# event-stream stub (per ADR-020)
# ----------------------------------------------------------------------------

# TTL for the per-tenant A2A pinned-token cache. Tokens are read from Vault
# on cache miss + refreshed before TTL elapses. Default 3600s matches Sprint-5
# mcp_oauth_token_cache_ttl_s for operational consistency.
# COGNIC_A2A_TOKEN_CACHE_TTL_S=3600

# Retention window for A2A artifact references stored via ObjectStoreAdapter.
# Default 7 days (604800s); tenants override per regulatory class.
# COGNIC_A2A_ARTIFACT_RETENTION_SECONDS=604800

# Inline-vs-store threshold for A2A artifact bytes. Payloads <= threshold ride
# inline in the Task envelope; larger payloads are persisted via the
# ObjectStoreAdapter and returned as ArtifactRef. 64 KiB matches the A2A 1.0
# spec recommendation; banks with stricter inline caps override downward.
# COGNIC_A2A_ARTIFACT_INLINE_THRESHOLD_BYTES=65536

# Pinned A2A spec version. Bumping requires an explicit reviewed change tied
# to the schema-drift CI gate (T6) — never silent. Pattern: ^[0-9]+\.[0-9]+$
# COGNIC_A2A_PINNED_SPEC_VERSION=1.0

# Whether the schema-drift CI gate runs at startup. False locally (saves the
# network round-trip on every test run); the dedicated CI lane sets the var
# to true. The drift gate itself is at
# tests/unit/protocol/test_a2a_schema_drift.py.
# COGNIC_A2A_SCHEMA_DRIFT_CHECK_ENABLED=false

# Maximum size of a detached AgentCard JWS file the trust gate accepts. JWS
# files >64 KiB are an attack vector (DoS via large-blob signature
# verification + memory pressure on the trust-gate path).
# COGNIC_A2A_CARD_JWS_MAX_SIZE_BYTES=65536

# Timeout for outbound A2A HTTP calls (Agent Card fetch + task dispatch).
# Per Doctrine Decision B — outbound dispatch URLs come from JWS-verified
# Agent Cards only.
# COGNIC_A2A_OUTBOUND_REQUEST_TIMEOUT_S=30

# Deadline for inbound non-streaming A2A handle() calls before the endpoint
# emits task.failed with deadline_exceeded. Streaming tasks use the spec's
# task-progress envelopes instead.
# COGNIC_A2A_INBOUND_REQUEST_TIMEOUT_S=60

# CI opt-in for the upstream A2A schema-drift check
# (tests/unit/protocol/test_a2a_schema_drift.py — pulls upstream protobuf +
# JSON-schema bindings; needs network). The dedicated CI lane sets this; local
# dev skips by default.
# COGNIC_RUN_A2A_UPSTREAM=1
